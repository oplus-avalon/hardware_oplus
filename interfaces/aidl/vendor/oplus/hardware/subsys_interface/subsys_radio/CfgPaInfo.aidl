package vendor.oplus.hardware.subsys_interface.subsys_radio;

@VintfStability
parcelable CfgPaInfo {
    int onOff = 0;
    int techType = 0;
    int band = 0;
    int rfMode = 0;
    int regAddr0 = 0;
    int regAddr1 = 0;
    int regAddr2 = 0;
    int addr0Range0 = 0;
    int addr0Range1 = 0;
    int addr0Range2 = 0;
    int addr0Range3 = 0;
    int addr1Range0 = 0;
    int addr1Range1 = 0;
    int addr1Range2 = 0;
    int addr1Range3 = 0;
    int addr2Range0 = 0;
    int addr2Range1 = 0;
    int addr2Range2 = 0;
    int addr2Range3 = 0;
}
